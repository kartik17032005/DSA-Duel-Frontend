rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ─────────────────────────────────────
    match /users/{uid} {
      allow read;                              // leaderboard reads
      allow write: if request.auth.uid == uid; // only own doc

      match /duel_history/{docId} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // ── Matchmaking queue ─────────────────────────────────────
    match /matchmaking_queue/{uid} {
      // Anyone signed in can read (to find opponents)
      allow read: if request.auth != null;
      // Only write your own entry
      allow create, update: if request.auth.uid == uid;
      allow delete: if request.auth.uid == uid;
    }

    // ── Duel rooms ────────────────────────────────────────────
    match /duel_rooms/{roomId} {
      // Both players can read
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.player1.uid ||
         request.auth.uid == resource.data.player2.uid);

      // Room creation: only by a participant
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.player1.uid;

      // Updates: only by participants, and only allowed fields
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.player1.uid ||
         request.auth.uid == resource.data.player2.uid);
    }

    // ── Questions (read-only for clients) ─────────────────────
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;  // only admin SDK can write questions
    }
  }
}